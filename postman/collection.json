      "name": "Pets",
      "item": [
        {
          "name": "Criar Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[200] Status code é 200', () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('[PERF] Tempo de resposta < 3000ms', () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                  "});\r",
                  "\r",
                  "pm.test('[HEADER] Content-Type contém application/json', () => {\r",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');\r",
                  "});\r",
                  "\r",
                  "let json;\r",
                  "pm.test('[BODY] Resposta é JSON válido', () => {\r",
                  "    pm.expect(() => { json = pm.response.json(); }).to.not.throw();\r",
                  "});\r",
                  "\r",
                  "if (json) {\r",
                  "    pm.test('[CAMPO] id é número', () => {\r",
                  "        pm.expect(json.id).to.be.a('number');\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] name é string não vazia', () => {\r",
                  "        pm.expect(json.name).to.be.a('string').and.not.empty;\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] name é \"doggie\"', () => {\r",
                  "        pm.expect(json.name).to.eql('doggie');\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] status é \"available\"', () => {\r",
                  "        pm.expect(json.status).to.eql('available');\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] status é valor válido da enum', () => {\r",
                  "        pm.expect(['available', 'pending', 'sold']).to.include(json.status);\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] photoUrls é array', () => {\r",
                  "        pm.expect(json.photoUrls).to.be.an('array');\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] tags é array', () => {\r",
                  "        pm.expect(json.tags).to.be.an('array');\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] category é objeto com id e name', () => {\r",
                  "        pm.expect(json.category).to.be.an('object');\r",
                  "        pm.expect(json.category).to.have.property('id');\r",
                  "        pm.expect(json.category).to.have.property('name');\r",
                  "    });\r",
                  "\r",
                  "    pm.test('[CAMPO] tags[0] tem id e name', () => {\r",
                  "        if (json.tags.length > 0) {\r",
                  "            pm.expect(json.tags[0]).to.have.property('id');\r",
                  "            pm.expect(json.tags[0]).to.have.property('name');\r",
                  "        }\r",
                  "    });\r",
                  "\r",
                  "    pm.environment.set('pet_id', json.id);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
